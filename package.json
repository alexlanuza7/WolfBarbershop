{
  "name": "wolf-barbershop",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start -c",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "web": "expo start -c --web",
    "check": "npm run typecheck && npm run lint",
    "doctor": "node scripts/doctor.js",
    "db:start": "node scripts/supabase-cli.js start",
    "db:stop": "node scripts/supabase-cli.js stop",
    "db:status": "node scripts/supabase-cli.js status",
    "db:reset": "node scripts/supabase-cli.js db reset",
    "db:test": "node scripts/supabase-cli.js test db",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/anton": "^0.4.2",
    "@expo-google-fonts/archivo": "^0.4.2",
    "@expo-google-fonts/big-shoulders-display": "^0.2.3",
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.99.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "lucide-react-native": "^1.8.0",
    "nativewind": "4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "^0.76.9",
    "react-native-css-interop": "0.1.22",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.8.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.19.13",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.3.3"
  }
